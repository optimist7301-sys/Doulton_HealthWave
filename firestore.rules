rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: consultations
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - contact: string (required, 1-50 chars)
    //   - concernArea: string (required, enum: 무릎, 어깨, 허리, 피부, 항노화, 기타)
    //   - status: string (required, enum: 통증 있음, 만성, 재발, 예방/관리)
    //   - contactMethod: string (required, enum: phone, text, kakao)
    //   - createdAt: timestamp (required)
    //   - userId: string (optional, matches auth.uid if present)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "optimist7301@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['name', 'contact', 'concernArea', 'status', 'contactMethod', 'createdAt']) &&
             data.keys().hasOnly(['name', 'contact', 'concernArea', 'status', 'contactMethod', 'createdAt', 'userId']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.contact is string && data.contact.size() >= 1 && data.contact.size() <= 50 &&
             data.concernArea in ['무릎', '어깨', '허리', '피부', '항노화', '기타'] &&
             data.status in ['통증 있음', '만성', '재발', '예방/관리'] &&
             data.contactMethod in ['phone', 'text', 'kakao'] &&
             data.createdAt is timestamp &&
             (!('userId' in data) || (data.userId is string && data.userId == request.auth.uid));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /consultations/{consultationId} {
      // Allow anyone to create a consultation request (Lead generation)
      allow create: if isValidConsultation(request.resource.data);
      
      // Only admins can read, update, or delete consultations
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
